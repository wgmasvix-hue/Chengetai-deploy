#!/usr/bin/env bash

set -e

SCRIPT_PATH="$(readlink -f "$0")"
export CHENGETAI_HOME="${CHENGETAI_HOME:-$(cd "$(dirname "$SCRIPT_PATH")" && pwd)}"

VERSION="$(cat "$CHENGETAI_HOME/VERSION" 2>/dev/null || echo unknown)"

show_help() {

cat <<HELP

=========================================================
        ChengetAi Deploy v${VERSION}
=========================================================

One Command. Complete Deployment.

Usage:

 chengetai install                    Install or update ChengetAi Deploy on this server
 chengetai doctor                     Check the system and install missing dependencies
 chengetai create [platform] [name]   Create a new deployment profile
 chengetai deploy [platform|name]     Deploy a repository (creates a profile if needed)
 chengetai start [name]               Start a deployment
 chengetai stop [name]                Stop a deployment
 chengetai restart [name]             Restart services
 chengetai status [name]              Show service status
 chengetai logs [name] [service...]   View logs
 chengetai backup [name]              Create a backup
 chengetai restore [name] [dir]       Restore a backup
 chengetai update                     Update ChengetAi Deploy and its deployments
 chengetai remove [name]              Remove a deployment
 chengetai version                    Show version information
 chengetai help                       Display all commands

Platforms: dspace (koha, moodle and ojs coming soon)

HELP

}

CMD="${1:-}"
[ $# -gt 0 ] && shift

case "$CMD" in

install|doctor|create|deploy|start|stop|restart|status|logs|backup|restore|update|remove)
    exec bash "$CHENGETAI_HOME/lib/$CMD.sh" "$@"
    ;;

version)
    echo "ChengetAi Deploy Version $VERSION"
    ;;

help|"")
    show_help
    ;;

*)
    echo "Unknown command: $CMD"
    show_help
    exit 1
    ;;
esac
