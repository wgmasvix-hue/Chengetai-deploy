#!/usr/bin/env bash

VERSION="1.0.0"
INSTALL_DIR="/opt/chengetai-deploy"

clear

echo "========================================================"
echo "          ChengetAi Deploy : DSpace 8.3"
echo "========================================================"
echo ""
echo "One Command. Complete Deployment."
echo ""
echo "Version : $VERSION"
echo ""

case "$1" in
    deploy)
        bash "$INSTALL_DIR/lib/deploy.sh"
        ;;
    doctor)
        bash "$INSTALL_DIR/lib/doctor.sh"
        ;;
    help|"")
        echo "Usage:"
        echo "  chengetai deploy"
        echo "  chengetai doctor"
        echo "  chengetai help"
        ;;
    version)
        echo "$VERSION"
        ;;
    *)
        echo "Unknown command: $1"
        ;;
esac
