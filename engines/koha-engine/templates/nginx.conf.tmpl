# ============================================================
#  ChengetAi Koha Engine — Nginx Reverse Proxy Configuration
#  Template: variables substituted by scripts/install.sh via envsubst.
#  ${OPAC_DOMAIN}       Public domain for the OPAC (patron catalogue)
#  ${STAFF_DOMAIN}      Public domain for the Staff interface
#  ${HTTPS_PORT}        External HTTPS port for OPAC  (default 443)
#  ${HTTPS_STAFF_PORT}  External HTTPS port for Staff (default 8443)
#  ${OPAC_INTERNAL_PORT}  Apache OPAC  port inside koha container
#  ${STAFF_INTERNAL_PORT} Apache Staff port inside koha container
# ============================================================

# ── Redirect all HTTP traffic to HTTPS ───────────────────────────────────────
server {
    listen      ${HTTP_PORT:-80};
    server_name _;

    # Allow Let's Encrypt ACME challenges through
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── OPAC — Public Catalogue ──────────────────────────────────────────────────
server {
    listen      ${HTTPS_PORT} ssl;
    server_name ${OPAC_DOMAIN};

    ssl_certificate     /etc/nginx/ssl/koha.crt;
    ssl_certificate_key /etc/nginx/ssl/koha.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security headers
    add_header X-Frame-Options        "SAMEORIGIN"   always;
    add_header X-Content-Type-Options "nosniff"      always;
    add_header X-XSS-Protection       "1; mode=block" always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    client_max_body_size 100M;

    location / {
        proxy_pass         http://koha:${OPAC_INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-Port  $server_port;
        proxy_read_timeout 300s;
        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
    }
}

# ── Staff Interface ───────────────────────────────────────────────────────────
server {
    listen      ${HTTPS_STAFF_PORT} ssl;
    server_name ${STAFF_DOMAIN};

    ssl_certificate     /etc/nginx/ssl/koha.crt;
    ssl_certificate_key /etc/nginx/ssl/koha.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security headers
    add_header X-Frame-Options        "SAMEORIGIN"   always;
    add_header X-Content-Type-Options "nosniff"      always;
    add_header X-XSS-Protection       "1; mode=block" always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    # Restrict staff interface to trusted networks (uncomment to enable)
    # allow 10.0.0.0/8;
    # allow 172.16.0.0/12;
    # allow 192.168.0.0/16;
    # deny  all;

    client_max_body_size 100M;

    location / {
        proxy_pass         http://koha:${STAFF_INTERNAL_PORT}/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-Port  $server_port;
        proxy_read_timeout 300s;
        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
    }
}
