#!/usr/bin/env bash
set -e

SCRIPT_PATH="$(readlink -f "$0")"
export CHENGETAI_HOME="${CHENGETAI_HOME:-$(cd "$(dirname "$SCRIPT_PATH")" && pwd)}"
VERSION="$(cat "$CHENGETAI_HOME/VERSION" 2>/dev/null || echo unknown)"

show_help() {
cat <<HELP
=========================================================
        ChengetAI Deploy v${VERSION}
=========================================================

One Command. Complete Deployment.

Usage:
 chengetai install                    Install or update ChengetAI Deploy
 chengetai doctor                     Check system and dependencies
 chengetai create [platform] [name]   Create a deployment profile
 chengetai deploy [platform|name]     Deploy an application
 chengetai start [name]               Start a deployment
 chengetai stop [name]                Stop a deployment
 chengetai restart [name]             Restart services
 chengetai status [name]              Show service status
 chengetai logs [name] [service]      View logs
 chengetai backup [name]              Create a backup
 chengetai restore [name] [dir]       Restore a backup
 chengetai edit <component> [name]    Edit configuration
 chengetai update                     Update deployments
 chengetai remove [name]              Remove a deployment
 chengetai enroll <token>             Enrol this server with the ChengetAi control plane
 chengetai agent <run|once|status>    Fleet agent (heartbeat + remote commands)
 chengetai version                    Show version
 chengetai help                       This help

Platforms: dspace, koha, moodle, ojs, wordpress

HELP
}

CMD="${1:-}"
[ $# -gt 0 ] && shift

case "$CMD" in
install|doctor|deploy|start|stop|restart|status|logs|backup|restore|edit|update|remove)
    # Route to platform-specific scripts
    PLATFORM="${1:-}"
    
    # Check if it's a Koha deployment
    if [ "$CMD" = "deploy" ] && [ "$PLATFORM" = "koha" ]; then
        exec bash "$CHENGETAI_HOME/lib/koha-deploy.sh" "${@:2}"
    fi
    
    # Check if it's a Koha management command
    if [ -d "$CHENGETAI_HOME/deployments/$PLATFORM" ] && [ -f "$CHENGETAI_HOME/deployments/$PLATFORM/.chengetai/deployment.yaml" ]; then
        PLUGIN=$(grep "plugin:" "$CHENGETAI_HOME/deployments/$PLATFORM/.chengetai/deployment.yaml" | cut -d: -f2 | tr -d ' ')
        if [ "$PLUGIN" = "koha" ]; then
            exec bash "$CHENGETAI_HOME/lib/koha-manage.sh" "$CMD" "$PLATFORM"
        fi
    fi
    
    # Default to existing engine
    exec bash "$CHENGETAI_HOME/lib/$CMD.sh" "$@"
    ;;

enroll|agent)
    # Fleet control-plane commands (managed deployments).
    exec bash "$CHENGETAI_HOME/lib/$CMD.sh" "$@"
    ;;

create)
    PLATFORM="${1:-}"
    NAME="${2:-}"
    
    if [ "$PLATFORM" = "koha" ]; then
        echo "Creating Koha deployment profile: ${NAME:-library}"
        mkdir -p "$CHENGETAI_HOME/deployments/${NAME:-library}"
        exec bash "$CHENGETAI_HOME/lib/koha-deploy.sh" "${NAME:-library}" "${3:-library.example.org}"
    fi
    
    exec bash "$CHENGETAI_HOME/lib/create.sh" "$@"
    ;;

version)
    echo "ChengetAI Deploy Version $VERSION"
    echo "Supported platforms: dspace, koha, moodle, ojs, wordpress"
    ;;

help|"")
    show_help
    ;;

*)
    echo "Unknown command: $CMD"
    show_help
    exit 1
    ;;
esac
